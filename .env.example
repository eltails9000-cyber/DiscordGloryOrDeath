# ─── Required ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN = os.getenv("DISCORD_TOKEN")

# ─── Bot identity ─────────────────────────────────────────────────────────────
BOT_PREFIX=!
BOT_DESCRIPTION=A multi-purpose Discord bot
OWNER_IDS=1042929958286266540      # comma-separated Discord user IDs

# ─── Guild (optional — restricts slash command registration to one guild) ──────
# GUILD_ID=123456789

# ─── Channels (paste channel IDs) ─────────────────────────────────────────────
CHANNEL_WELCOME=1470485711479247020
CHANNEL_LEAVE=1478899060885819441
CHANNEL_LOGS=1527020603973042416
CHANNEL_MOD_LOGS=1527020603973042416
CHANNEL_VERIFICATION=1527014755586281556
CHANNEL_ANNOUNCEMENTS=1527014635620794538
CHANNEL_SUGGESTIONS=1470463232803213428
CHANNEL_SECURITY_LOGS=1527017311192617010

# ─── Roles ────────────────────────────────────────────────────────────────────
ROLE_VERIFIED=1470258621043572846
ROLE_MUTED=
ROLE_MOD=1479972733457793297
ROLE_ADMIN=1471259209600471212
ROLE_UNVERIFIED=

# ─── Moderation ───────────────────────────────────────────────────────────────
MOD_WARN_THRESHOLD_MUTE=3
MOD_WARN_THRESHOLD_KICK=5
MOD_WARN_THRESHOLD_BAN=7
MOD_DEFAULT_MUTE_DURATION=600

# ─── Security ─────────────────────────────────────────────────────────────────
SECURITY_ANTI_SPAM_ENABLED=true
SECURITY_ANTI_RAID_ENABLED=true
SECURITY_ANTI_SCAM_ENABLED=true
SECURITY_ANTI_INVITE_ENABLED=true
SECURITY_ANTI_MASS_MENTION_ENABLED=true
SECURITY_SPAM_THRESHOLD=5
SECURITY_SPAM_INTERVAL=5
SECURITY_SPAM_MUTE_DURATION=300
SECURITY_RAID_JOIN_THRESHOLD=10
SECURITY_RAID_INTERVAL=10
SECURITY_RAID_LOCKDOWN_DURATION=300
SECURITY_MASS_MENTION_THRESHOLD=5
SECURITY_MIN_ACCOUNT_AGE=7

# ─── Verification ─────────────────────────────────────────────────────────────
VERIFICATION_MIN_ACCOUNT_AGE=7
VERIFICATION_CAPTCHA_LENGTH=6
VERIFICATION_CAPTCHA_TIMEOUT=120
VERIFICATION_MAX_ATTEMPTS=3

# ─── Giveaways ────────────────────────────────────────────────────────────────
GIVEAWAY_DEFAULT_WINNERS=1
GIVEAWAY_MIN_DURATION=60
GIVEAWAY_MAX_DURATION=2592000

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY = os.getenv("PENAI_API_KEY")
OPENAI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.7
AI_COOLDOWN_SECONDS=10
AI_SYSTEM_PROMPT=You are a helpful assistant for a Discord server.

# ─── Announcements ────────────────────────────────────────────────────────────
POLL_DEFAULT_DURATION=86400

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=bot/data/database.db
DATABASE_BACKUP_DIR=bot/data/backups/

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=bot/data/logs/
LOG_FILE=bot.log
